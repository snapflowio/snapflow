{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "builder": "swc",
    "typeCheck": true,
    "assets": ["assets/**/*", "generated/**/*"],
    "watchAssets": true,
    "tsConfigPath": "tsconfig.app.json"
  }
}
