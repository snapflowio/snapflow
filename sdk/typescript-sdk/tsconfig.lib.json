{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"rootDir": "../../",
		"outDir": "../../dist/out-tsc",
		"module": "NodeNext",
		"moduleResolution": "nodenext",
		"types": ["bun"],
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"target": "es2022",
		"declaration": true,
		"resolveJsonModule": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["jest.config.ts", "src/**/*.spec.ts", "src/**/*.test.ts"]
}
