{
	"name": "@snapflow/sdk",
	"version": "0.1.1",
	"description": "Official TypeScript SDK for Snapflow",
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			}
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"scripts": {
		"build": "tsup",
		"validate": "publint",
		"prepublishOnly": "bun run build && bun run validate"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/snapflowio/snapflow.git",
		"directory": "sdk/typescript-sdk"
	},
	"homepage": "https://github.com/snapflowio/snapflow/tree/main/sdk/typescript-sdk#readme",
	"bugs": {
		"url": "https://github.com/snapflowio/snapflow/issues"
	},
	"keywords": [
		"snapflow",
		"sdk",
		"sandbox",
		"automation",
		"cloud"
	],
	"engines": {
		"node": ">=18.0.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"author": "Snapflow",
	"license": "Apache-2.0",
	"dependencies": {
		"axios": "^1.11.0",
		"dotenv": "^17.2.1",
		"form-data": "^4.0.4",
		"ws": "^8.20.0"
	},
	"devDependencies": {
		"@snapflow/api-client": "workspace:*",
		"@snapflow/toolbox-client": "workspace:*",
		"@types/ws": "^8.18.1",
		"publint": "^0.3.18",
		"tsup": "^8.5.1"
	}
}
