{
  "name": "api-client-go",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/api-client-go",
  "tags": [],
  "targets": {
    "test": {
      "executor": "@nx-go/nx-go:test"
    },
    "build": {
      "executor": "@nx-go/nx-go:build",
      "options": {
        "main": "./{projectRoot}",
        "outputPath": "dist/packages/api-client-go"
      }
    },
    "lint": {
      "executor": "@nx-go/nx-go:lint"
    },
    "generate:api-client": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm openapi-generator-cli generate -i dist/apps/api/openapi.json -g go --additional-properties=packageName=apiclient,moduleVersion=$DEFAULT_PACKAGE_VERSION,generateInterfaces=true,enumClassPrefix=true,structPrefix=true -o packages/api-client-go"
      }
    },
    "tidy": {
      "executor": "@nx-go/nx-go:tidy"
    }
  }
}