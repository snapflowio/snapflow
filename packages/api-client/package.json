{
  "name": "@snapflow/api-client",
  "version": "0.0.1",
  "license": "MIT",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate:api-client": "openapi-generator-cli generate -i ../../dist/apps/api/openapi.json -g typescript-axios -o . --additional-properties=useSingleRequestParameter=true,withSeparateModelsAndApi=true",
    "format": "biome format src --write || true",
    "lint": "biome check .",
    "lint:fix": "biome check . --write"
  },
  "dependencies": {
    "axios": "^1.6.1"
  },
  "devDependencies": {
    "@types/node": "12.11.5 - 12.20.42",
    "typescript": "^4.0 || ^5.0"
  }
}
