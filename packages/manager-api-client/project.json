{
  "name": "manager-api-client",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/manager-api-client",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/manager-api-client",
        "tsConfig": "packages/manager-api-client/tsconfig.lib.json",
        "packageJson": "packages/manager-api-client/package.json",
        "main": "packages/manager-api-client/index.ts",
        "updateBuildableProjectDepsInPackageJson": true
      }
    },
    "generate:api-client": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "bun run openapi-generator-cli generate --git-repo-id=snapflow --git-user-id=snapflow -i apps/manager/pkg/api/docs/swagger.json -g typescript-axios --additional-properties=supportsES6=true,typescriptThreePlus=true,withSeparateModelsAndApi=true,apiPackage=api,modelPackage=models,useTags=true,enumPropertyNaming=UPPERCASE --type-mappings=DateTime=Date -o packages/manager-api-client/src",
          "bun nx format manager-api-client"
        ],
        "parallel": false
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd {projectRoot} && bun run format"
      }
    }
  },

  "tags": []
}
