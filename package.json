{
  "name": "snapflow",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "format": "turbo format",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "db:generate": "turbo db:generate",
    "db:push": "turbo db:push",
    "db:generate-production": "turbo db:generate-production",
    "db:push-production": "turbo db:push-production",
    "openapi:generate": "turbo openapi",
    "generate:api-client": "turbo generate:api-client",
    "build:executor": "turbo build --filter=@snapflow/executor",
    "serve:executor": "turbo serve --filter=@snapflow/executor",
    "test:executor": "turbo test --filter=@snapflow/executor",
    "openapi:executor": "turbo openapi --filter=@snapflow/executor"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.6",
    "@openapitools/openapi-generator-cli": "^2.21.0",
    "@swc-node/register": "^1.10.10",
    "@swc/cli": "^0.7.7",
    "@swc/core": "^1.12.9",
    "@swc/helpers": "^0.5.17",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "jiti": "^2.4.2",
    "lint-staged": "^16.1.2",
    "markdownlint-cli2": "^0.18.1",
    "prettier": "^3.6.2",
    "swc-loader": "^0.2.6",
    "tslib": "^2.8.1",
    "turbo": "^2.5.6",
    "verdaccio": "^6.1.5",
    "webpack-cli": "^6.0.1",
    "webpack-node-externals": "^3.0.0"
  },
  "dependencies": {
    "openapi": "^1.0.1"
  }
}
