{
	"name": "snapflow",
	"version": "0.1.0",
	"license": "AGPL-3.0",
	"private": true,
	"workspaces": [
		"web",
		"sdk/typescript-sdk",
		"clients/api-client-ts",
		"clients/toolbox-client-ts",
		"examples/basic"
	],
	"packageManager": "bun@1.3.10",
	"scripts": {
		"postinstall": "is-ci || husky",
		"build:web": "cd web && bun run build",
		"lint": "bunx biome check .",
		"format": "bunx biome format ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@commitlint/cli": "^20.4.2",
		"@commitlint/config-conventional": "^20.4.2",
		"@openapitools/openapi-generator-cli": "^2.30.0",
		"@types/bun": "^1.3.11",
		"husky": "^9.1.7",
		"is-ci": "^4.1.0",
		"lint-staged": "^16.2.7",
		"typescript": "^5.9.3"
	},
	"lint-staged": {
		"*.{ts,tsx}": [
			"biome format . --write"
		]
	}
}
