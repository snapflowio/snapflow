{
	"compileOnSave": false,
	"compilerOptions": {
		"sourceMap": true,
		"declaration": false,
		"moduleResolution": "bundler",
		"importHelpers": false,
		"target": "ES2022",
		"module": "esnext",
		"lib": ["es2022", "dom"],
		"skipLibCheck": true,
		"skipDefaultLibCheck": true,
		"paths": {
			"@snapflow/api-client": ["./clients/api-client-ts/src/index.ts"],
			"@snapflow/toolbox-client": ["./clients/toolbox-client-ts/src/index.ts"]
		}
	},
	"exclude": ["node_modules", "tmp"]
}
